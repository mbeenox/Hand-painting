{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024,
      "excludeFiles": "{**/cv2/data/**,**/numpy/tests/**,**/numpy/**/tests/**,**/*.pyi}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
